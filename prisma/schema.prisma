generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  VENDOR
  ADMIN
}

enum OfferingType {
  SERVICE
  PRODUCT
}

enum QuoteRequestStatus {
  DRAFT
  SUBMITTED
  RESPONDED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum OrderStatus {
  draft
  awaiting_vendor
  quoted
  awaiting_payment
  paid
  in_progress
  completed
  canceled
  refunded
}

enum ReportTargetType {
  VENDOR
  OFFERING
  REVIEW
  MESSAGE
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
  ACTIONED
}

enum QuotePaymentPreference {
  DEPOSIT
  FULL
}

enum CategoryAudience {
  VENDOR
  BUYER
}

enum ListingStatus {
  DRAFT
  ACTIVE
  EXPIRED
  SOLD
  INACTIVE
}

enum ListingFeeEventType {
  PUBLISH
  MANUAL_RENEW
  AUTO_RENEW
  SOLD_UNIT_RENEW
}

enum OffsiteAdsTier {
  STANDARD
  HIGH_VOLUME
}

enum PayoutStatus {
  PENDING
  READY
  PAID
  CANCELED
}

enum RefundStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ReviewReminderType {
  FIRST_FOLLOW_UP
  SECOND_FOLLOW_UP
}

enum InquiryStatus {
  NEW
  REVIEWED
  CLOSED
}

model User {
  id                     String            @id @default(cuid())
  name                   String?
  email                  String?           @unique
  emailVerified          DateTime?
  passwordHash           String?
  image                  String?
  username               String?           @unique
  bio                    String?
  instagramUrl           String?
  tiktokUrl              String?
  partyfulUrl            String?
  partyPhotoUrls         String[]
  role                   UserRole          @default(BUYER)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  vendorProfile          VendorProfile?
  avatar                 UserAvatar?
  partyEvents            PartyEvent[]
  following              Follow[]          @relation("Follower")
  followers              Follow[]          @relation("Following")
  seller                 Seller?
  buyerFavorites         Favorite[]        @relation("BuyerFavorites")
  buyerQuotes            QuoteRequest[]    @relation("BuyerQuoteRequests")
  buyerOrders            Order[]           @relation("BuyerOrders")
  vendorOrders           Order[]           @relation("VendorOrders")
  buyerReviews           Review[]          @relation("BuyerReviews")
  sentMessages           Message[]         @relation("SentMessages")
  conversationsAsBuyer   Conversation[]    @relation("ConversationBuyer")
  conversationsAsVendor  Conversation[]    @relation("ConversationVendor")
  reports                Report[]          @relation("ReporterReports")
  accounts               Account[]
  sessions               Session[]
}

model UserAvatar {
  id          String   @id @default(cuid())
  userId      String   @unique
  contentType String
  data        Bytes
  size        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Seller {
  id                 String          @id @default(cuid())
  userId             String          @unique
  defaultShopId      String?         @unique
  offsiteAdsEnabled  Boolean         @default(false)
  offsiteAdsTier     OffsiteAdsTier  @default(STANDARD)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultShop        Shop?           @relation("SellerDefaultShop", fields: [defaultShopId], references: [id], onDelete: SetNull)
  shops              Shop[]          @relation("SellerShops")
  listings           Listing[]
  orders             Order[]         @relation("SellerOrders")
  payouts            Payout[]
  refunds            Refund[]        @relation("SellerRefunds")
  listingFeeEvents   ListingFeeEvent[]
  reviewResponses    ReviewResponse[]
}

model Shop {
  id                     String            @id @default(cuid())
  sellerId               String
  vendorProfileId        String?           @unique
  slug                   String            @unique
  name                   String
  noMonthlySubscription  Boolean           @default(true)
  active                 Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  seller                 Seller            @relation("SellerShops", fields: [sellerId], references: [id], onDelete: Cascade)
  vendorProfile          VendorProfile?    @relation(fields: [vendorProfileId], references: [id], onDelete: SetNull)
  defaultForSeller       Seller?           @relation("SellerDefaultShop")
  listings               Listing[]
  orders                 Order[]           @relation("ShopOrders")
  payouts                Payout[]
  listingFeeEvents       ListingFeeEvent[]
}

model VendorProfile {
  id                        String                @id @default(cuid())
  userId                    String                @unique
  slug                      String                @unique
  username                  String?               @unique
  name                      String
  website                   String?
  bio                       String?
  city                      String
  state                     String?
  zipCode                   String?
  locationLat               Float?
  locationLng               Float?
  serviceRadiusMiles        Int                   @default(15)
  photos                    String[]
  coverPhoto                String?
  logoUrl                   String?
  verified                  Boolean               @default(false)
  stripeAccountId           String?
  stripeOnboardingComplete  Boolean               @default(false)
  averageRating             Float                 @default(0)
  reviewCount               Int                   @default(0)
  startingPriceCents        Int?
  serviceAreaNotes          String?
  availabilityNotes         String?
  weekendAvailable          Boolean               @default(true)
  depositEnabled            Boolean               @default(true)
  depositPercent            Int                   @default(30)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt

  user                      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop                      Shop?
  offerings                 Offering[]
  categories                VendorCategory[]
  quoteRequests             QuoteRequest[]        @relation("VendorQuoteRequests")
  conversations             Conversation[]
  orders                    Order[]               @relation("VendorOrdersByProfile")
  reviews                   Review[]              @relation("VendorReviews")
  sellerRatingAggregate     SellerRatingAggregate?
  rankingScore              RankingScore?
  favorites                 Favorite[]            @relation("VendorFavorites")
  inquiries                 Inquiry[]
  taggedPartyEvents         PartyEvent[]            @relation("PartyEventTaggedVendors")
}

model PartyEvent {
  id            String   @id @default(cuid())
  userId        String
  slug          String   @unique
  title         String
  theme         String?
  tags          String[]
  description   String?
  coverImageUrl String?
  imageUrls     String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taggedVendors VendorProfile[] @relation("PartyEventTaggedVendors")
}

model Follow {
  id           String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt    DateTime @default(now())

  follower     User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following    User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Category {
  id         String            @id @default(cuid())
  name       String            @unique
  iconName   String
  audience   CategoryAudience  @default(VENDOR)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  offerings  Offering[]
  vendors    VendorCategory[]
}

model VendorCategory {
  id          String         @id @default(cuid())
  vendorId    String
  categoryId  String

  vendor      VendorProfile  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category    Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([vendorId, categoryId])
}

model Offering {
  id               String        @id @default(cuid())
  vendorId         String
  type             OfferingType
  title            String
  slug             String
  description      String
  basePriceCents   Int?
  categoryId       String
  tags             String[]
  photos           String[]
  active           Boolean       @default(true)
  durationMinutes  Int?
  turnaroundDays   Int?
  inventoryCount   Int?
  variantsJson     Json?
  addonsJson       Json?
  faqJson          Json?
  allowInstantBook Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  vendor           VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category         Category      @relation(fields: [categoryId], references: [id])
  listing          Listing?
  quoteRequests    QuoteRequest[]
  orders           Order[]
  inquiries        Inquiry[]

  @@unique([vendorId, slug])
}

model Listing {
  id                 String              @id @default(cuid())
  sellerId           String?
  shopId             String?
  offeringId         String?             @unique
  title              String
  category           String
  description        String
  priceFrom          Int?
  city               String
  quantity           Int                 @default(1)
  availableQuantity  Int                 @default(1)
  autoRenew          Boolean             @default(false)
  status             ListingStatus       @default(DRAFT)
  listingFeeFlatCents Int                @default(20)
  publishedAt        DateTime?
  expiresAt          DateTime?
  lastRenewedAt      DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  seller             Seller?             @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  shop               Shop?               @relation(fields: [shopId], references: [id], onDelete: SetNull)
  offering           Offering?           @relation(fields: [offeringId], references: [id], onDelete: SetNull)
  feeEvents          ListingFeeEvent[]
  orders             Order[]             @relation("ListingOrders")
  inquiries          Inquiry[]
}

model Inquiry {
  id               String        @id @default(cuid())
  vendorProfileId  String
  listingId        String?
  offeringId       String?
  name             String
  email            String
  phone            String?
  eventDate        DateTime?
  eventLocation    String
  budgetCents      Int?
  message          String?
  status           InquiryStatus @default(NEW)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  vendorProfile    VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  listing          Listing?      @relation(fields: [listingId], references: [id], onDelete: SetNull)
  offering         Offering?     @relation(fields: [offeringId], references: [id], onDelete: SetNull)
}

model ListingFeeEvent {
  id            String              @id @default(cuid())
  listingId     String
  sellerId      String
  shopId        String?
  orderId       String?
  eventType     ListingFeeEventType
  amountCents   Int
  notes         String?
  chargedAt     DateTime            @default(now())
  createdAt     DateTime            @default(now())

  listing       Listing             @relation(fields: [listingId], references: [id], onDelete: Cascade)
  seller        Seller              @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  shop          Shop?               @relation(fields: [shopId], references: [id], onDelete: SetNull)
  order         Order?              @relation("OrderListingFeeEvents", fields: [orderId], references: [id], onDelete: SetNull)
}

model QuoteRequest {
  id              String             @id @default(cuid())
  buyerId         String
  vendorId        String
  offeringId      String?
  eventDate       DateTime?
  eventLocation   String
  budgetCents     Int?
  notes           String?
  attachments     String[]
  status          QuoteRequestStatus @default(SUBMITTED)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  buyer           User               @relation("BuyerQuoteRequests", fields: [buyerId], references: [id], onDelete: Cascade)
  vendor          VendorProfile      @relation("VendorQuoteRequests", fields: [vendorId], references: [id], onDelete: Cascade)
  offering        Offering?          @relation(fields: [offeringId], references: [id], onDelete: SetNull)
  quote           Quote?
}

model Quote {
  id                  String                 @id @default(cuid())
  quoteRequestId      String                 @unique
  amountCents         Int
  depositAmountCents  Int?
  expiresAt           DateTime
  notes               String?
  lineItemsJson       Json?
  paymentPreference   QuotePaymentPreference @default(DEPOSIT)
  status              QuoteStatus            @default(SENT)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  quoteRequest        QuoteRequest           @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  orders              Order[]
}

model Conversation {
  id               String        @id @default(cuid())
  buyerId          String
  vendorId         String
  vendorProfileId  String
  lastMessageAt    DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  buyer            User          @relation("ConversationBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  vendor           User          @relation("ConversationVendor", fields: [vendorId], references: [id], onDelete: Cascade)
  vendorProfile    VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  messages         Message[]

  @@unique([buyerId, vendorId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  attachments    String[]
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model Order {
  id                    String               @id @default(cuid())
  buyerId               String
  vendorId              String
  vendorProfileId       String
  sellerId              String?
  shopId                String?
  listingId             String?
  offeringId            String?
  quoteId               String?
  amountCents           Int
  itemSubtotalCents     Int                  @default(0)
  shippingAmountCents   Int                  @default(0)
  taxAmountCents        Int                  @default(0)
  giftWrapAmountCents   Int                  @default(0)
  buyerTotalCents       Int                  @default(0)
  taxRemittedByMarketplace Boolean           @default(false)
  offsiteAdsAttributed  Boolean              @default(false)
  offsiteAdsTier        OffsiteAdsTier?
  stripePaymentIntentId String?              @unique
  stripeChargeId        String?
  status                OrderStatus          @default(draft)
  notes                 String?
  paymentSucceededAt    DateTime?
  completedAt           DateTime?
  reviewEligibleAt      DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  buyer                 User                 @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  vendor                User                 @relation("VendorOrders", fields: [vendorId], references: [id], onDelete: Cascade)
  vendorProfile         VendorProfile        @relation("VendorOrdersByProfile", fields: [vendorProfileId], references: [id], onDelete: Cascade)
  seller                Seller?              @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: SetNull)
  shop                  Shop?                @relation("ShopOrders", fields: [shopId], references: [id], onDelete: SetNull)
  listing               Listing?             @relation("ListingOrders", fields: [listingId], references: [id], onDelete: SetNull)
  offering              Offering?            @relation(fields: [offeringId], references: [id], onDelete: SetNull)
  quote                 Quote?               @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  review                Review?
  feeBreakdown          OrderFeeBreakdown?
  payout                Payout?
  refunds               Refund[]
  reviewReminders       ReviewReminder[]
  listingFeeEvents      ListingFeeEvent[]    @relation("OrderListingFeeEvents")
}

model OrderFeeBreakdown {
  id                                String    @id @default(cuid())
  orderId                           String    @unique
  itemSubtotalCents                 Int
  shippingAmountCents               Int
  taxAmountCents                    Int
  giftWrapAmountCents               Int
  listingFeeCents                   Int
  transactionFeeCents               Int
  paymentProcessingFeeCents         Int
  offsiteAdsFeeCents                Int
  totalFeesCents                    Int
  sellerNetPayoutCents              Int
  adjustedItemSubtotalCents         Int
  adjustedShippingAmountCents       Int
  adjustedTaxAmountCents            Int
  adjustedGiftWrapAmountCents       Int
  adjustedListingFeeCents           Int
  adjustedTransactionFeeCents       Int
  adjustedPaymentProcessingFeeCents Int
  adjustedOffsiteAdsFeeCents        Int
  adjustedTotalFeesCents            Int
  adjustedSellerNetPayoutCents      Int
  refundedAmountCents               Int       @default(0)
  lineItemsJson                     Json?
  createdAt                         DateTime  @default(now())
  updatedAt                         DateTime  @updatedAt

  order                             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payout {
  id                String       @id @default(cuid())
  sellerId          String
  shopId            String?
  orderId           String       @unique
  grossAmountCents  Int
  totalFeesCents    Int
  netAmountCents    Int
  status            PayoutStatus @default(PENDING)
  scheduledAt       DateTime?
  paidAt            DateTime?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  seller            Seller       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  shop              Shop?        @relation(fields: [shopId], references: [id], onDelete: SetNull)
  order             Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Refund {
  id                                String       @id @default(cuid())
  orderId                           String
  sellerId                          String
  amountCents                       Int
  reason                            String?
  status                            RefundStatus @default(PENDING)
  isFullRefund                      Boolean      @default(false)
  transactionFeeAdjustmentCents     Int          @default(0)
  paymentProcessingFeeAdjustmentCents Int        @default(0)
  offsiteAdsFeeAdjustmentCents      Int          @default(0)
  sellerNetAdjustmentCents          Int          @default(0)
  originalFeeValuesJson             Json?
  adjustedFeeValuesJson             Json?
  createdAt                         DateTime     @default(now())
  updatedAt                         DateTime     @updatedAt

  order                             Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  seller                            Seller       @relation("SellerRefunds", fields: [sellerId], references: [id], onDelete: Cascade)
}

model MarketplaceFeeConfig {
  id                              String    @id @default(cuid())
  singletonKey                    String    @unique @default("default")
  listingFeeFlatCents             Int       @default(20)
  listingDurationDays             Int       @default(120)
  transactionFeeBasisPoints       Int       @default(650)
  paymentProcessingBasisPoints    Int       @default(300)
  paymentProcessingFlatCents      Int       @default(25)
  offsiteAdsStandardBasisPoints   Int       @default(1500)
  offsiteAdsHighVolumeBasisPoints Int       @default(1200)
  offsiteAdsEnabled               Boolean   @default(true)
  transactionFeeRefundable        Boolean   @default(true)
  paymentProcessingFeeRefundable  Boolean   @default(false)
  rankingReviewCountWeight        Float     @default(3)
  rankingAverageRatingWeight      Float     @default(4)
  rankingRecentReviewsWeight      Float     @default(2)
  rankingCompletionRateWeight     Float     @default(2)
  rankingResponseRateWeight       Float     @default(1)
  rankingOnTimeDeliveryWeight     Float     @default(1)
  rankingRecencyWindowDays        Int       @default(30)
  rankingMinimumReviewsForBoost   Int       @default(3)
  fraudReviewVelocityThreshold    Int       @default(5)
  fraudLowRatingSpikeThreshold    Int       @default(3)
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt
}

model Review {
  id          String        @id @default(cuid())
  orderId      String       @unique
  buyerId      String
  vendorId     String
  rating       Int
  body         String?
  verifiedPurchase Boolean   @default(true)
  reviewerDisplayLabel String @default("Verified Purchase")
  flaggedForModeration Boolean @default(false)
  flaggedReason String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer        User         @relation("BuyerReviews", fields: [buyerId], references: [id], onDelete: Cascade)
  vendor       VendorProfile @relation("VendorReviews", fields: [vendorId], references: [id], onDelete: Cascade)
  response     ReviewResponse?
}

model ReviewResponse {
  id          String    @id @default(cuid())
  reviewId     String   @unique
  sellerId     String
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  review       Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  seller       Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

model SellerRatingAggregate {
  id                     String    @id @default(cuid())
  vendorProfileId        String    @unique
  averageRating          Float     @default(0)
  weightedAverageRating  Float     @default(0)
  totalReviews           Int       @default(0)
  recentReviews30d       Int       @default(0)
  completionRate         Float     @default(0)
  responseRate           Float     @default(0)
  onTimeDeliveryRate     Float     @default(0)
  flaggedReviewCount     Int       @default(0)
  lastReviewAt           DateTime?
  updatedAt              DateTime  @updatedAt

  vendorProfile          VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
}

model RankingScore {
  id                        String    @id @default(cuid())
  vendorProfileId           String    @unique
  score                     Float     @default(0)
  reviewCountComponent      Float     @default(0)
  ratingComponent           Float     @default(0)
  recentReviewComponent     Float     @default(0)
  completionComponent       Float     @default(0)
  responseComponent         Float     @default(0)
  onTimeDeliveryComponent   Float     @default(0)
  tierLabel                 String    @default("Rising")
  calculatedAt              DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  vendorProfile             VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
}

model ReviewReminder {
  id          String             @id @default(cuid())
  orderId      String
  reminderType ReviewReminderType
  sentAt       DateTime?
  createdAt    DateTime          @default(now())

  order        Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, reminderType])
}

model Favorite {
  id         String         @id @default(cuid())
  buyerId     String
  vendorId    String
  createdAt   DateTime      @default(now())

  buyer       User          @relation("BuyerFavorites", fields: [buyerId], references: [id], onDelete: Cascade)
  vendor      VendorProfile @relation("VendorFavorites", fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([buyerId, vendorId])
}

model Report {
  id          String         @id @default(cuid())
  reporterId   String
  targetType   ReportTargetType
  targetId     String
  reason       String
  status       ReportStatus  @default(OPEN)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  reporter     User          @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
